{
  "name": "agenda-por-voz",
  "version": "1.0.0",
  "description": "Asistente de agenda por voz para Telegram integrado con Google Calendar y Gemini AI",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "netlify dev",
    "deploy": "netlify deploy --prod",
    "deploy:preview": "netlify deploy",
    "test:local": "node --env-file=.env tests/test-local.js",
    "test:mock-voice": "node --env-file=.env tests/test-local.js --voice",
    "test:nlu": "node --env-file=.env tests/test-nlu-suite.js",
    "logs": "netlify functions:log telegram-bot"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "netlify-cli": "^17.37.3"
  }
}
