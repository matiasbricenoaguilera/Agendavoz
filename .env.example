# ─────────────────────────────────────────────────────────────
#  AGENDA POR VOZ — Variables de Entorno
#  Copia este archivo como .env y rellena cada valor.
#  NUNCA subas .env al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Telegram Bot ──────────────────────────────────────────────
# Token del bot obtenido desde @BotFather en Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ

# (Opcional) Token secreto para validar que el webhook viene de Telegram.
# Se configura al registrar el webhook con el parámetro secret_token.
TELEGRAM_WEBHOOK_SECRET=un_secreto_largo_y_aleatorio

# (Opcional) ID de chat de tu esposa. Si se define, el bot solo
# responde a mensajes provenientes de este chat (seguridad extra).
OWNER_CHAT_ID=987654321

# ── Google Gemini ─────────────────────────────────────────────
# API Key obtenida desde https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Google Calendar (Service Account) ────────────────────────
# ID del calendario donde se agendarán los eventos.
# Para el calendario principal de una cuenta de Gmail es: nombre@gmail.com
GOOGLE_CALENDAR_ID=nombre@gmail.com

# JSON completo de la Cuenta de Servicio de Google Cloud.
# Pega aquí el contenido del archivo .json descargado desde IAM,
# asegurándote de que sea una sola línea (sin saltos de línea).
# Ejemplo: {"type":"service_account","project_id":"...","private_key_id":"...",...}
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"mi-proyecto","private_key_id":"abc123","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"agenda-bot@mi-proyecto.iam.gserviceaccount.com","client_id":"123456789","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
